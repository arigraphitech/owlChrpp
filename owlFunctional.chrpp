owlHasValueObject(C,P,Y) #passive \ owlHasValueObject(C,P,Y) <=> true ;;
owlOneOf(C,S) #passive \ owlOneOf(C,S) <=> true ;;
owlOneOfLoop(C,IT,ITEND) #passive \ owlOneOfLoop(C,IT,ITEND) <=> true ;;
classification() #passive \ classification()<=> true ;;


//onto validity
//owlDisjointClass(A,B) is true if the A and B classes are disjoint
DisjointClass @ owlDisjointClass(A,B), owlClassAssertion(X,A,true), owlClassAssertion(X,B,true) <=> failure();;

//owlNegativeObjectAssertion(X,P,Y) is true if the two individuals X,Y are not connected by the property P
NegativeObjectAssertion @ owlNegativeObjectAssertion(X,P,Y),owlObjectPropertyAssertion(X,P,Y) <=> failure() ;;

//owlDisjointObjectProperty(A,B) is true if the list of properties L are disjoint
DisjointObjProperty @ owlDisjointObjectProperty(A,B),owlObjectPropertyAssertion(X,A,Y),owlObjectPropertyAssertion(X,B,Y) <=> failure() ;;

//owlDisjointDataProperty(A,B) is true if the list of data properties L are disjoint
DisjointDataProperty @ owlDisjointDataProperty(A,B),owlDataPropertyAssertion(X,A,Y),owlDataPropertyAssertion(X,B,Y) <=> failure() ;;

//owlNegativeDataAssertion(X,P,Y) is true if the individual X and the value Y are not connected by the property P
NegativeDataAssertion @ owlNegativeDataAssertion(X,P,Y),owlDataPropertyAssertion(X,P,Y) <=> failure() ;;

//owlIrreflexiveObjectProperty(P) is true if the property P is an irreflexive object property
irreflexiveProperty @ owlIrreflexiveObjectProperty(P),owlObjectPropertyAssertion(X,P,X)<=> failure();;


//onto schema inference
//If C1 is subclass of C2, then both C1 and C2 are classes
owlSubclassOf(C1,C2) ==> owlClass(C1) , owlClass(C2) ;;

//If X is an instance of class C, then C is a class and X is a named individual
owlClassAssertion(X,C,true) ==> owlClass(C) , owlNamedIndividual(X) ;;

//SubClassOf: every class is a subclass of itself (reflexivity)
//owlClass(A) ==> owlSubclassOf(A,A);;
owlSubclassOf(A,B), owlSubclassOf(B,C) ==> different(A,B,C) | owlSubclassOf(A,C);;

//Equivalent classes: every class is equivalent to itself (reflexivity)
owlClass(C) ==>   owlEquivalentClass(C,C);;

//If A is subclass of B and B is subclass of A, then A and B are equivalent classes
owlSubclassOf(A,B), owlSubclassOf(B,A) ==> !(A==B) | owlEquivalentClass(A,B);;


//owl:Thing and owl:Nothing: every class is a subclass of owl:Thing
owlClass(C) , logicalName(URIC,C)  ==> !(URIC==owlThing)| owlSubclassOf(C,owlThing);;

//owl:Nothing is a subclass of every class
owlClass(C) ==>  owlSubclassOf(owlNothing,C);;

//Object property: every object property is a sub-property of itself and equivalent to itself
owlObjectProperty(P) ==> owlSubObjectPropertyOf(P,P), owlEquivalentObjectProperty(P,P);;

//Data property: every data property is a sub-property of itself and equivalent to itself
owlDataProperty(P) ==>  owlEquivalentDataProperty(P,P), owlSubDataPropertyOf(P,P) ;; 

//Transitive sub-property: if A is sub-property of B and B is sub-property of C, then A is sub-property of C
owlSubObjectPropertyOf(A,B), owlSubObjectPropertyOf(B,C) ==> different(A,B,C) | owlSubObjectPropertyOf(A,C);;
owlSubDataPropertyOf(A,B), owlSubDataPropertyOf(B,C) ==> different(A,B,C) | owlSubDataPropertyOf(A,C);;

//Equivalent properties imply sub-property relationships in both directions
owlEquivalentObjectProperty(A,B) ==> !(A==B) | owlSubObjectPropertyOf(A,B), owlSubObjectPropertyOf(B,A);;
owlEquivalentDataProperty(A,B) ==> !(A==B) | owlSubDataPropertyOf(A,B), owlSubDataPropertyOf(B,A);;

//If A is sub-property of B and B is sub-property of A, then A and B are equivalent properties
owlSubObjectPropertyOf(A,B), owlSubObjectPropertyOf(B,A) ==> !(A==B) | owlEquivalentObjectProperty(A,B);;
owlSubDataPropertyOf(A,B), owlSubDataPropertyOf(B,A) ==> !(A==B) | owlEquivalentDataProperty(A,B);;

//Domain and range propagation
//If property P has domain C1 and C1 is subclass of C2, then P also has domain C2
owlObjectPropertyDomain(P,C1), owlSubclassOf(C1,C2) ==> !(C1==C2) | owlObjectPropertyDomain(P,C2);;

//If property P1 is sub-property of P2 and P2 has domain C, then P1 also has domain C
owlObjectPropertyDomain(P2,C), owlSubObjectPropertyOf(P1,P2) ==> !(P1==P2) | owlObjectPropertyDomain(P1,C);;

//If property P has range C1 and C1 is subclass of C2, then P also has range C2
owlObjectPropertyRange(P,C1), owlSubclassOf(C1,C2) ==> !(C1==C2) | owlObjectPropertyRange(P,C2);;

//If property P1 is sub-property of P2 and P2 has range C, then P1 also has range C
owlObjectPropertyRange(P2,C), owlSubObjectPropertyOf(P1,P2) ==>  !(P1==P2) | owlObjectPropertyRange(P1,C);;

//Domain propagation for data properties
owlDataPropertyDomain(P2,C), owlSubDataPropertyOf(P1,P2) ==> !(P1==P2) | owlDataPropertyDomain(P1,C);;

//Range propagation for data properties
owlDataPropertyRange(P2,C), owlSubDataPropertyOf(P1,P2) ==>  !(P1==P2) | owlDataPropertyRange(P1,C);;


//owlDataPropertyDomain(P,DP) is true if the property P has the domain DP (an object)
//owlDataPropertyRange(P,DP) is true if the property P has the range DP (a DataType)
DataPropertyDomain @ owlDataPropertyDomain(P,DP) , owlDataPropertyAssertion(X,P,_) ==> owlClassAssertion(X,DP,true) ;;
DataPropertyRange @ owlDataPropertyRange(P,DR) , owlDataPropertyAssertion(_,P,Y) <=> invalidType(DR,Y) | failure();;

//owlClassAssertion(X,A,true) is true if X is an instance of A
//owlSubclassOf(A,B) is true if A is a subclass of B
subclass @ owlSubclassOf(A,B) ,owlClassAssertion(X,A,true) ==> !(A==B) |  owlClassAssertion(X,B,true) ;;

//owlEquivalentClass(A,B) is true if the class A is equivalent with the class B
equivalentClass @ owlEquivalentClass(A,B),owlClassAssertion(X,A,true) ==> !(A==B) |owlClassAssertion(X,B,true);;

owlEquivalentClass(A,B) ==> !(A==B)  | owlSubclassOf(A,B) ;;

//ObjectPropertyAssertion(X,P,Y) is true if the individual X has the property P with the value Y
// owlSubPropertyOf(P2,P1)  is true if P2 is a subPropertyof the property P1
subObjproperty @ owlSubObjectPropertyOf(P2,P1) , owlObjectPropertyAssertion(X,P2,Y) ==> !(P2==P1) | owlObjectPropertyAssertion(X,P1,Y) ;;
subDataProperty @ owlSubDataPropertyOf(P2,P1) , owlDataPropertyAssertion(X,P2,Y) ==> !(P2==P1) | owlDataPropertyAssertion(X,P1,Y) ;;

//owlObjectPropertyDomain(P,DP) is true if the property P has the domain DP (an object)
//owlObjectPropertyRange(P,DP) is true if the property P has the range DP (an object)
objectPropertydomain @ owlObjectPropertyDomain(P,DP) , owlObjectPropertyAssertion(X,P,Y) ==> owlClassAssertion(X,DP,true) ;;
objectPropertyCoDomain @ owlObjectPropertyRange(P,DP) , owlObjectPropertyAssertion(X,P,Y) ==> owlClassAssertion(Y,DP,true) ;;

//owlSameIndividual(X,Y) is true if X and Y refer to (denote) the same individual
sameIndividual1 @ owlSameIndividual(X,Y) ==> !(X==Y) |  owlSameIndividual(Y,X)  ;;
sameIndividual2 @ owlSameIndividual(X,Y) ,  owlSameIndividual(Y,Z) ==> !(X==Y) && !(Y==Z) && !(X==Z)  | owlSameIndividual(X,Z) ;;
sameIndividual3 @ owlSameIndividual(X,Y), owlObjectPropertyAssertion(X,P,O) ==> !(X==Y) |  owlObjectPropertyAssertion(Y,P,O);;
sameIndividual4 @ owlSameIndividual(X,Y), owlDataPropertyAssertion(X,P,O) ==> !(X==Y) |  owlDataPropertyAssertion(Y,P,O);; 
sameIndividual5 @ owlSameIndividual(O1,O2), owlObjectPropertyAssertion(X,P,O1) ==> !(O1==O2) |  owlObjectPropertyAssertion(X,P,O2);;  
sameIndividual6 @ owlSameIndividual(X,Y), owlClassAssertion(X,C,B) ==> !(X==Y) |  owlClassAssertion(Y,C,B);;
sameIndividual7 @ owlSameIndividual(X,Y), owlClassAssertion(Y,C,B) ==> !(X==Y) |  owlClassAssertion(X,C,B);;

//owlDifferentIndividual(X,Y) is true if it's excluded that X and Y are the same individual
DifferentIndividual @ owlDifferentIndividual(X,Y) ,owlSameIndividual(X,Y) <=>  failure();;


//owlInverseObjectProperty( P1,P2 ) is true if P1 is the inverse object property of P2
inverseProperty @ owlInverseObjectProperty(P1,P2) , owlObjectPropertyAssertion(X,P1,Y) ==> owlObjectPropertyAssertion(Y,P2,X);;
owlInverseObjectProperty(P1,P2) ==> owlInverseObjectProperty(P2,P1)  ;;

//owlSymmetricObjectProperty(P) is true if P is a symmetric object property
symmetricProperty @ owlSymmetricObjectProperty(P),owlObjectPropertyAssertion(X,P,Y) ==> owlObjectPropertyAssertion(Y,P,X) ;;

//owlAsymmetricObjectProperty(P) is true if P is an asymmetric object property
// Si P(X,Y) existe et P est asymétrique, alors ¬P(Y,X) doit être vrai
AsymmetricProperty1 @ owlAsymmetricObjectProperty(P),owlObjectPropertyAssertion(X,P,Y) ==> owlNegativeObjectAssertion(Y,P,X) ;;

//owlreflexiveProperty(P) is true if P is a reflexive object property
reflexiveProperty @ owlReflexiveObjectProperty(P),owlObjectPropertyAssertion(X,P,Y) ==> owlObjectPropertyAssertion(X,P,X),owlObjectPropertyAssertion(Y,P,Y);;

//owlFunctionalObjectProperty(P) is true if P is a functional object property
functionalObjProperty @ owlFunctionalObjectProperty(P),owlObjectPropertyAssertion(X,P,Y),owlObjectPropertyAssertion(X,P,Z) ==> !(Y==Z) | owlSameIndividual(Y,Z);;

//owlFunctionalDataProperty(P) is true if P is a functional data property
//Note: Pour les data properties, Y et Z sont de type Value, pas des individus
//On vérifie simplement qu'ils sont égaux, sinon échec
functionalDataProperty @ owlFunctionalDataProperty(P),owlDataPropertyAssertion(X,P,Y),owlDataPropertyAssertion(X,P,Z) <=> !(Y==Z) | failure();;

//owlInverseFunctionalObjectProperty(P) is true if P is an inverse functional object property
inverseFunctional @ owlInverseFunctionalObjectProperty(P),owlObjectPropertyAssertion(X,P,Z),owlObjectPropertyAssertion(Y,P,Z) ==> !(X==Y) | owlSameIndividual(X,Y);;

//owlTransitiveObjectProperty(P) is true if P is a transitive object property
// Changed guard: allow X==Z (reflexivity via symmetric+transitive) but prevent X==Y or Y==Z to avoid trivial loops
transitiveObjectProperty @ owlTransitiveObjectProperty(P),owlObjectPropertyAssertion(X,P,Y),owlObjectPropertyAssertion(Y,P,Z) ==> !(X==Y) && !(Y==Z) | owlObjectPropertyAssertion(X,P,Z);;

//Extract data value information from data property assertions (needed for DataSomeValuesFrom)
owlDataPropertyAssertion(X,P,Y) ==> owlDataValue(Y,(*Y).val,(*Y).typeVal) ;;

//UnionOf: initialize loop to iterate over all classes in the union set
owlUnionOf(C, S) ==> owlUnionOfLoop(C, (*S).begin(), (*S).end()) ;;

//UnionOf loop: base case - when iterator reaches the end, succeed
owlUnionOfLoop(C,ITEND,ITEND) <=> success();;

//UnionOf loop: recursive case - add each class from the set as a union class and continue
owlUnionOfLoop(C,IT,ITEND) <=> owlUnionClass(C,**IT),owlUnionOfLoop(C,std::next(*IT),ITEND);;

//UnionOf inference: if X is instance of one class V in the union, then X is instance of the union class C
owlClassAssertion(X,V,true) \ owlUnionClass(C,V) <=> owlClassAssertion(X,C,true);;

//Avoid recomputing the same union: if two classes have the same union set, they are equivalent
owlUnionOf(C1, S),owlUnionOf(C2, S) ==> owlEquivalentClass(C1,C2) ;; 



//IntersectionOf: initialize loop to iterate over all classes in the intersection set
r0 @ owlIntersectionOf(C,S) ==> owlIntersectionOfLoop(C,(*S).begin(),(*S).end(),0) ;;

//IntersectionOf loop: recursive case - process each class in the intersection and continue with incremented index
r1 @ owlIntersectionOfLoop(C,IT,ITEND,I) <=> !(IT==ITEND) | owlIntersectionClass(C,**IT,I),owlIntersectionOfLoop(C,std::next(*IT),ITEND,I+1);;

//IntersectionOf first pass: add all individuals of the first class as candidates for the intersection
r2 @ owlClassAssertion(X,V,true) , owlIntersectionClass(C,V,0) ==> owlCandidatsIntersection(X,C,0) ;;

//IntersectionOf filtering: if individual belongs to the new class and was a candidate, it remains a candidate for next round
r3 @ owlIntersectionClass(C,V,I) , owlCandidatsIntersection(X,C,I) ,owlClassAssertion(X,V,true)  ==> owlCandidatsIntersection(X,C,I+1) ;;

//IntersectionOf finalization: when a candidate reaches the final count (matching the loop index), assert it belongs to the intersection
r5 @ owlCandidatsIntersection(X,C,I) , owlIntersectionOfLoop(C,ITEND,ITEND,I)  ==> owlClassAssertion(X,C,true)  ;;

//IntersectionOf reverse inference: if X is instance of intersection class C, then X is instance of each class C1 in the intersection
r6 @ owlIntersectionClass(C,C1,_),owlClassAssertion(X,C,true) ==> owlClassAssertion(X,C1,true) ;;

//IntersectionOf subclass inference: if C2 is subclass of intersection C1, then C2 is also subclass of each component of the intersection
r7 @owlIntersectionClass(C1,Component,_), owlSubclassOf(C2,C1) ==> !(C1==C2) | owlSubclassOf(C2,Component) ;;

//IntersectionOf subclass reverse: Si A est sous-classe de TOUS les composants d'une intersection I (avec 2 composants), alors A ⊆ I
// Version pour intersection à 2 éléments (le cas le plus courant)
r7b @ owlIntersectionOfLoop(I,ITEND,ITEND,2), owlIntersectionClass(I,C1,0), owlIntersectionClass(I,C2,1),
      owlSubclassOf(A,C1), owlSubclassOf(A,C2) 
==> !(I==A) | owlSubclassOf(A,I) ;;


//ComplementOf: initialize all named individuals as potentially not in the complement class
owlComplementOf(A,NOTA),owlNamedIndividual(X) ==> owlClassAssertion(X,NOTA,false) ;;


//ComplementOf: remove false assertion if individual is actually in the complement class
owlClassAssertion(X,NOTA,true) \ owlClassAssertion(X,NOTA,false) <=> true ;;

//ComplementOf: remove false assertion if individual is in the original class A (thus not in complement)
owlComplementOf(A,NOTA),owlClassAssertion(X,A,true) \ owlClassAssertion(X,NOTA,false) <=> true ;;

//ObjectSomeValuesFrom: if U has property P to V and V is instance of Y, then U is instance of ∃P.Y
owlObjectSomeValuesFrom(C,P,Y) , owlObjectPropertyAssertion(U,P,V) , owlClassAssertion(V,Y,true) ==> owlClassAssertion(U,C,true) ;;

//ObjectSomeValuesFrom: if U is instance of ∃P.Y, then U must have property P to some V that is instance of Y (witness creation)
owlObjectSomeValuesFrom(C,P,Y), owlClassAssertion(U,C,true) ==>    owlObjectPropertyAssertion(U,P,V),logicalName(emptyString,V),owlClassAssertion(V,Y,true);;

//ObjectSomeValuesFrom cleanup: remove anonymous witness if a named individual already exists
owlObjectPropertyAssertion(U,P,W),logicalName(URI,W) #passive,owlClassAssertion(W,Y,true) \ owlObjectPropertyAssertion(U,P,V),logicalName(emptyString,V) ,owlClassAssertion(V,Y,true) <=> !(URI==emptyString)| success() ;;

//DataSomeValuesFrom: if U has data property P with value V of valid type, then U is instance of ∃P.DR
owlDataSomeValuesFrom(C,P,DR) , owlDataPropertyAssertion(U,P,V) ==> ! invalidType(DR,V) | owlClassAssertion(U,C,true) ;;

//DataSomeValuesFrom: if U is instance of ∃P.DR, then U must have data property P with some value of type DR (witness creation)
owlDataSomeValuesFrom(C,P,DR), owlClassAssertion(U,C,true) ==> owlDataPropertyAssertion(U,P,createValue(V,DR)),logicalName(emptyString,V);;

//DataSomeValuesFrom cleanup: remove anonymous data value witness if a named value already exists
owlDataPropertyAssertion(U,P,W),owlDataValue(W,ValW,TypeW)\owlDataValue(V,emptyString,TypeV), owlDataPropertyAssertion(U,P,V)<=> sameDataType(TypeV,TypeW) && !(ValW==emptyString)| success() ;;


//ObjectMaxCardinality(0): if U is instance of ≤0 P, then U cannot have any property P assertion (failure)
owlObjectMaxCardinality(C,P,0) , owlClassAssertion(U,C,true) , owlObjectPropertyAssertion(U,P,_) <=> failure() ;;

//ObjectMaxCardinality(1): if U is instance of ≤1 P and has P to both Y1 and Y2, then Y1 and Y2 must be the same individual
owlObjectMaxCardinality(C,P,1) , owlClassAssertion(U,C,true) , owlObjectPropertyAssertion(U,P,Y1) , owlObjectPropertyAssertion(U,P,Y2) <=> !(Y1==Y2) | owlSameIndividual(Y1,Y2) ;;

//DataMaxCardinality(0): if U is instance of ≤0 P, then U cannot have any data property P assertion (failure)
owlDataMaxCardinality(C,P,0) , owlClassAssertion(U,C,true) , owlDataPropertyAssertion(U,P,_) <=> failure() ;;

//DataMaxCardinality(1): if U is instance of ≤1 P and has P to both Y1 and Y2, they must be equal values (else failure)
owlDataMaxCardinality(C,P,1) , owlClassAssertion(U,C,true) , owlDataPropertyAssertion(U,P,Y1) , owlDataPropertyAssertion(U,P,Y2) <=> !(Y1==Y2) | failure() ;;

//HasValue (object): if U is instance of ∃P.{Y}, then U has property P to the specific individual Y
owlHasValueObject(C,P,Y),owlObjectProperty(P),owlClassAssertion(U,C,true) ==> owlObjectPropertyAssertion(U,P,Y) ;;

//HasValue (object) reverse: if U has property P to Y, then U is instance of ∃P.{Y}
owlHasValueObject(C,P,Y),owlObjectPropertyAssertion(U,P,Y) ==> owlClassAssertion(U,C,true) ;;

//HasValue subsumption: si C ≡ HasValue(P, A) et A est instance de Y, et qu'il existe SV ≡ SomeValuesFrom(P, Y),
//alors C est sous-classe de SV (car HasValue(P, a) ⊆ SomeValuesFrom(P, type(a)))
hasValueSubsumption @ owlHasValueObject(C, P, A), owlClassAssertion(A, Y, true), owlObjectSomeValuesFrom(SV, P, Y) 
==> owlSubclassOf(C, SV) ;;

//HasValue subsumption avec hiérarchie de propriétés: si C ≡ HasValue(P1, A) et P1 ⊆ P2 et A:Y, et SV ≡ SomeValuesFrom(P2, Y),
//alors C ⊆ SV (car HasValue(P1, a) ⊆ SomeValuesFrom(P2, type(a)) si P1 ⊆ P2)
hasValueSubsumptionProp @ owlHasValueObject(C, P1, A), owlSubObjectPropertyOf(P1, P2), 
                          owlClassAssertion(A, Y, true), owlObjectSomeValuesFrom(SV, P2, Y) 
==> owlSubclassOf(C, SV) ;;

//OneOf: initialize loop to iterate over all individuals in the enumeration set
owlOneOf(C, S) ==> owlOneOfLoop(C, (*S).begin(), (*S).end()) ;;

//OneOf loop: base case - when iterator reaches the end, succeed
owlOneOfLoop(C,ITEND,ITEND) <=> success();;

//OneOf loop: recursive case - each individual in the set is an instance of the OneOf class
owlOneOfLoop(C,IT,ITEND) <=> owlClassAssertion(**IT,C,true),owlOneOfLoop(C,std::next(*IT),ITEND);;

// chain property
// Passive rule to prevent duplicate constructPropertyChain constraints
constructPropertyChain(PC,I,X,Y,N) #passive \ constructPropertyChain(PC,I,X,Y,N) <=> true ;;
ObjectPropertyChain @ owlObjectPropertyChain(PC,P,0,N) , owlObjectPropertyAssertion(X,P,Y) ==> constructPropertyChain(PC,0,X,Y,N) ;;
chainStep @ owlObjectPropertyAssertion(Y,P,Z), owlObjectPropertyChain(PC,P,J,N), constructPropertyChain(PC,I,X,Y,N) ==> I<N && equalIncrement(J,I) | constructPropertyChain(PC,I+1,X,Z,N) ;;
finalChain @ constructPropertyChain(PC,N,X,Y,N) <=> owlObjectPropertyAssertion(X,PC,Y) ;;

//owlHasKey
 owlHasKey(C,P),owlClassAssertion(X,C,true),owlClassAssertion(Y,C,true) ==> !(X==Y) | owlHasKeyLoop(X,Y, (*P).begin(), (*P).end()) ;;
 owlHasKeyLoop(X,Y,ITEND,ITEND) <=> owlSameIndividual(X,Y) ;;
 owlObjectPropertyAssertion(X,P,V1), owlObjectPropertyAssertion(Y,P,V1) \ owlHasKeyLoop(X,Y,IT,ITEND) <=> (P == **IT) | owlHasKeyLoop(X,Y,std::next(*IT),ITEND) ;;
 owlDataPropertyAssertion(X,P,V1), owlDataPropertyAssertion(Y,P,V1) \ owlHasKeyLoop(X,Y,IT,ITEND)  <=> (P == **IT) | owlHasKeyLoop(X,Y,std::next(*IT),ITEND) ;;



//Display result: convert logical name to URI and display
res(URIC) ==> afficher(URIC);;

//querySuperClassOfUri: query to retrieve all superclasses of a class given its URI  
querySuperClassOfUri(URIC) , logicalName(URIC,X) #passive ==> querySuperClassOf(X), res(std::string("owl:Thing")) ;;

//querySuperClassOf: add current class to results first
querySuperClassOf(X) , logicalName(URIC,X) #passive==> res(URIC) ;;

//querySuperClassOf: recursively follow subclass relationships to find all superclasses up to the root
querySuperClassOf(X) , owlSubclassOf(X,Y) ==> !(X==Y) | querySuperClassOf(Y) , queryEquivalentClass(X) ;;

//retrieve the equivalent classes of a class X
queryEquivalentClass(X) ,  owlEquivalentClass(X,Y), logicalName(URIY,Y)#passive ==> !(X==Y) | res(URIY) ;;

//querySubClassOf: query to retrieve all subclasses of a class
querySubClassOfUri(URIC) , logicalName(URIC,X) #passive ==> querySubClassOf(X) , res(URIC) ;;

//querySubClassOf: recursively follow subclass relationships to find all subclasses  
r_querySubClassOf1 @ querySubClassOf(X), owlSubclassOf(Y,X), logicalName(URIY,Y) #passive ==> 
    !(X==Y) | querySubClassOf(Y),queryEquivalentClass(X), res(URIY) ;;



//queryClassification: query to retrieve all classes that an individual is instance of (with true classification)
queryClassificationUri(URIX), logicalName(URIX,X) #passive ==> queryClassification(X) ;;

//queryClassification: add all direct class assertions to results AND recursively get superclasses
r_queryClassification1 @ queryClassification(X), owlClassAssertion(X,C,true), logicalName(URIC,C) #passive ==> 
    res(URIC), querySuperClassOf(C) , queryEquivalentClass(C);;



//queryInstance(X,C) return true if X is instance of class C
rule1 @ logicalName(URIC,C) #passive ,logicalName(URIX,X) #passive \ queryInstanceURI(URIX,URIC) <=> queryInstance(X,C) ;;
rule2 @ owlClassAssertion(X,C,true) \ queryInstance(X,C)<=> afficher("true");;
rule3 @ queryInstance(X,C)<=> afficher("false");;



//teste realisation : CR owlBENCH
resultRealisation(URIX,URIY) ==> ! prefixIntern(URIY)| stockerRealisation(URIX,URIY);;

//cas general x et c sont differents
loopRealisation @ queryClassificationReal(X), owlClassAssertion(X,C,true), logicalName(URIC,C) #passive ,logicalName(URIX,X) #passive ==>  resultRealisation(URIX,URIC), resultRealisation(URIX,owlThing), querySuperClassOfReal(X,C) , queryEquivalentClassReal(X,C);;
// Cas spécial : X et C sont la même variable (punning)
loopRealisationSame @ queryClassificationReal(X), owlClassAssertion(X,X,true), logicalName(URI,X) #passive ==> resultRealisation(URI,URI), resultRealisation(URI,owlThing), querySuperClassOfReal(X,X) , queryEquivalentClassReal(X,X);;
querySuperClassOfReal(I,C) , logicalName(URIC,C) #passive , logicalName(URII,I) #passive ==>  resultRealisation(URII,URIC) ;;
querySuperClassOfReal(I,X) , owlSubclassOf(X,Y) ==> !(X==Y) | querySuperClassOfReal(I,Y) , queryEquivalentClassReal(I,X) ;;
queryEquivalentClassReal(I,X) ,  owlEquivalentClass(X,Y), logicalName(URIY,Y) #passive ,logicalName(URII,I) #passive ==> !(X==Y) |  resultRealisation(URII,URIY) ;;

realisation() , owlNamedIndividual(X), logicalName(URIX,X) #passive ==> queryClassificationReal(X) ;;

//teste classification : CT owlBENCH
resultClassification(URIX,URIY) ==> ! prefixIntern(URIY) &&     ! prefixIntern(URIX) | stockerClassification(URIX,URIY);;

classification(), owlSubclassOf(X,Y) , logicalName(URIX,X) #passive , logicalName(URIY,Y) #passive  ==> resultClassification(URIX,URIY);;
classification(), owlSubclassOf(X,owlThing) , logicalName(URIX,X) #passive  ==> resultClassification(URIX,owlThing);;
classification(), owlSubclassOf(X,X) , logicalName(URIX,X) #passive  ==> resultClassification(URIX,URIX) ;;

//translate sparql querries (OWLBENCH)
ResultSet(S,ID) ==> afficherResultatSet(S,ID);;

//query 1, 2, 5, 6, 8, 9, 16 : SELECT  DISTINCT  ?x  ?y  WHERE { ?x  :isMemberOf  ?y  }
// Step 1: Immediately assign ID when query is received
queryObjAssertionUri(URIP) <=> queryObjAssertionWithId(URIP, get_next_id()) ;;
// Step 2: If logicalName exists, process the query
logicalName(URIP,P) \ queryObjAssertionWithId(URIP, ID) <=> queryObjAssertion(P, ID) ;;
// Step 3: Fallback if no logicalName (consume the query without results)
queryObjAssertionWithId(URIP, ID) <=> success() ;;
//cas general
queryObjAssertion(P,ID) , owlObjectPropertyAssertion(X,P,Y) , logicalName(URIX,X) #passive ,logicalName(URIY,Y) #passive==> ResultSet(makeSet(URIX,URIY),ID);;
//cas specian X==Y 
queryObjAssertion(P,ID) , owlObjectPropertyAssertion(X,P,X) , logicalName(URIX,X) #passive ==> ResultSet(makeSet(URIX,URIX),ID);;
queryObjAssertion(P,ID) <=> success();;

//query 3 : SELECT  DISTINCT  ?x  ?y  WHERE { ?x  :hasAge  ?y  }
queryDataAssertionUri(URIP) <=> queryDataAssertionWithId(URIP, get_next_id()) ;;
logicalName(URIP,P) \ queryDataAssertionWithId(URIP, ID) <=> queryDataAssertion(P, ID) ;;
queryDataAssertionWithId(URIP, ID) <=> success() ;;
queryDataAssertion(P,ID) , owlDataPropertyAssertion(X,P,Y) , logicalName(URIX,X)  ==> ResultSet(makeSet(URIX,valueToString(Y)),ID);;
queryDataAssertion(P,ID) <=> success();;

//query 4, 10, 11, 12, 15 : SELECT  DISTINCT  ?x  WHERE { ?x  rdf:type  :T20CricketFan  }
queryInstancesURI(URIC) <=> queryInstancesWithId(URIC, get_next_id()) ;;
logicalName(URIC,C) \ queryInstancesWithId(URIC, ID) <=> queryInstances(C, ID) ;;
queryInstancesWithId(URIC, ID) <=> success() ;;
queryInstances(C,ID) , owlClassAssertion(X,C,true) , logicalName(URIX,X) #passive ==> ResultSet(makeSet(URIX,emptyString),ID);;
queryInstances(C,ID) <=> success() ;;

//query 7 : SELECT DISTINCT ?x WHERE { ?x :hasCollegeDiscipline :NonScience }
queryObjAssertionSubjectUri(URIP,URIO) <=> queryObjAssertionSubjectWithId(URIP, URIO, get_next_id()) ;;
logicalName(URIP,P), logicalName(URIO,O) \ queryObjAssertionSubjectWithId(URIP, URIO, ID) <=> queryObjAssertionSubject(P,O, ID) ;;
queryObjAssertionSubjectWithId(URIP, URIO, ID) <=> success() ;;
queryObjAssertionSubject(P,O,ID) , owlObjectPropertyAssertion(X,P,O) , logicalName(URIX,X) #passive  ==> ResultSet(makeSet(URIX,emptyString),ID);;
queryObjAssertionSubject(P,O,ID) <=> success();;

//query 13, 14 : SELECT  DISTINCT  ?x ?y WHERE {?x  :isHeadOf  ?y}
querySubjectByObjectUri(URIP) <=> querySubjectByObjectWithId(URIP, get_next_id()) ;;
logicalName(URIP,P) \ querySubjectByObjectWithId(URIP, ID) <=> querySubjectByObject(P, ID) ;;
querySubjectByObjectWithId(URIP, ID) <=> success() ;;
querySubjectByObject(P,ID) , owlObjectPropertyAssertion(X,P,Y) , logicalName(URIX,X) #passive , logicalName(URIY,Y) #passive ==> ResultSet(makeSet(URIX,URIY),ID);;
querySubjectByObject(P,ID) <=> success();;

//query 17 : SELECT DISTINCT ?x ?y WHERE {?x rdf:type :Student. ?x :isStudentOf ?y. ?y :isPartOf ?z . ?z :hasCollegeDiscipline :Engineering}
