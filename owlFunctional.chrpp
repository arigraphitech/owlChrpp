//owlOneOfLoop(C,ITEND,ITEND) <=> success();;
//owlOneOfLoop(C,IT,ITEND) <=> owlClassAssertion(**IT,C,true),owlOneOfLoop(C,std::next(*IT),ITEND);;


//owlHasKey
// owlHasKey(E,P,C),owlClassAssertion(X,C,true),owlClassAssertion(Y,C,true) ==> !(X==Y) | owlHasKeyLoop( (*P).begin(), (*P).end(),X,Y) ;;
// owlHasKeyLoop(ITEND,ITEND,X,Y) <=> owlSameIndividual(X,Y) ;;
// owlObjectPropertyAssertion(X,P,V1), owlObjectPropertyAssertion(Y,P,V1) \ owlHasKeyLoop(IT,ITEND,X,Y) <=> (P == **IT) | owlHasKeyLoop(std::next(*IT),ITEND,X,Y) ;;
// owlDataPropertyAssertion(X,P,V1), owlDataPropertyAssertion(Y,P,V1) \ owlHasKeyLoop(IT,ITEND,X,Y)  <=> (P == **IT) | owlHasKeyLoop(std::next(*IT),ITEND,X,Y) ;;








//querries
//querySuperClassOf recupere toutes les super classes d'une classe ainsi que leur superClass jusqu'a la racine
querySuperClassOfUri(URIC) , logicalName(URIC,X) ==> querySuperClassOf(X) ;;
querySuperClassOf(X)\ owlSubclassOf(X,Y) <=> !(X==Y) | res(Y) , querySuperClassOf(Y) ;;
querySuperClassOf(X) <=> res(X) ;;
res(X), logicalName(URIC,X) ==> afficher(URIC);;

//querySubClassOf recupere toutes les sous classes d'une classe
