            queryDataAssertionWithId(+std::string,+int),
            querySubjectByObjectWithId(+std::string,+int),
            queryObjAssertionSubjectWithId(+std::string,+std::string,+int),
            queryEngineeringStudentsWithId(+std::string,+std::string,+std::string,+std::string,+std::string,+int),
            queryComplexStudentsWithId(+std::string,+std::string,+std::string,+std::string,+std::string,+int)

            


//suppression des doublons
owlPrefix(X,Y) #passive \ owlPrefix(X,Y) <=> true ;;
owlClass(C) #passive \ owlClass(C) <=> true ;;
