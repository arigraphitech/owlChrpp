############################
#   Object Properties
############################

# Object Property: owl2bench:advises (owl2bench:advises)

EquivalentObjectProperties(owl2bench:advises owl2bench:isAdvisorOf)

# Object Property: owl2bench:dislikes (owl2bench:dislikes)

ObjectPropertyDomain(owl2bench:dislikes owl2bench:Person)
DisjointObjectProperties(owl2bench:dislikes owl2bench:likes)

# Object Property: owl2bench:enrollFor (owl2bench:enrollFor)

FunctionalObjectProperty(owl2bench:enrollFor)
ObjectPropertyDomain(owl2bench:enrollFor owl2bench:Student)
ObjectPropertyRange(owl2bench:enrollFor owl2bench:Program)

# Object Property: owl2bench:enrollIn (owl2bench:enrollIn)

SubObjectPropertyOf(owl2bench:enrollIn owl2bench:isStudentOf)
